# GitHub Personal Access Token
# Scopes required: repo, workflow
GITHUB_PAT=ghp_xxxx

# Claude Code OAuth token — generated with: claude setup-token
# Uses your Claude Max subscription. Do NOT use an API key here.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxx

# Target repo for the loop (owner/repo format)
CLAW_REPO=pA1nD/claw-studio

# Poll interval in seconds (default: 60)
CLAW_POLL_INTERVAL=60
