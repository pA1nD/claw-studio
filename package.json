{
  "name": "claw-studio",
  "version": "0.0.1",
  "description": "Claw your way. — Autonomous software factory.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "claw": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-templates.mjs",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'benchmark/**/*.ts' --no-error-on-unmatched-pattern",
    "test": "vitest run",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.benchmark.json",
    "benchmark": "tsx benchmark/harness.ts"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.0.0",
    "execa": "^8.0.0",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-sealedbox-js": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
